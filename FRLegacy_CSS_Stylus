@-moz-document domain("flightrising.com") {
/* === OUTER MODULE === */

  #fr-layout-player-module {
    background-color: #b8a888 !important;
    border: 2px solid #8a6a40 !important;
    border-radius: 4px !important;
  }

  #fr-layout-player-module-main {
    background-color: #c8b898 !important;
    border: 2px solid #8a6a40 !important;
    border-radius: 3px !important;
  }

  .fr-layout-player-module-username {
    color: #6b2000 !important;
    font-family: Verdana, sans-serif;
    font-size: 15px !important;
    padding: 0px 0px 3px;
  }

  .fr-layout-player-module-left {
    border-right: 1px solid #8a6a40 !important;
    background-color: #c0a880 !important;
  }

  .theme-background-main-5,
  .theme-background-alt-5 {
    background-color: #eddcba !important;
  }

  .theme-border-5 {
    border-color: #8a6a40 !important;
  }

  .theme-text-accent-5 {
    color: #6b2000 !important;
  }


/* === ENERGY METER === */

  /* Hide fill bar but keep text visible */
  #fr-layout-player-module .common-meter-full {
    display: none !important;
  }

  /* Keep text floating over the PNG */
  #fr-layout-player-module .common-meter-text {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 10px !important;
    font-family: Verdana, sans-serif !important;
    color: #1a1a1a !important;
    z-index: 1 !important;
  }

  /* Make sure the meter frame is position relative */
  #fr-layout-player-module .common-meter-frame {
    position: relative !important;
  }

  #fr-layout-player-module #fr-layout-player-module-energy-meter,
  #fr-layout-player-module .common-meter-frame {
    height: 20px !important;
    min-height: unset !important;
    border-radius: 0 !important;
    border: none !important;
    overflow: hidden !important;
    background-image: url("data:image/jpeg;base64,") !important;
    background-size: 100% 100% !important;
    background-color: transparent !important;
  }

  #fr-layout-player-module #fr-layout-player-module-energy-meter [data-state="full"],
  #fr-layout-player-module #fr-layout-player-module-energy-meter .common-meter-empty {
    display: none !important;
  }

  #fr-layout-player-module .fr-layout-player-module-energy-meter-line {
    display: none !important;
  }



/* === CURRENCIES === */

#fr-layout-player-module-currencies {
    border: 1px solid #8a6a40 !important;
    background-color: #eddcba !important;
    display: grid !important;
    grid-template-columns: auto auto;
    justify-content: space-around !important;
    align-items: center !important;
    padding: 0px 0 0px -10px!important;
  }


#fr-layout-player-module-treasure{
    font-family: Times New Roman, sans-serif !important;
    font-size: xx-small;
}

 #fr-layout-player-module-treasure a {
    background-image: url("data:image/png;base64,") !important;
    background-size: 90% 60% !important;
  }


  /* === NOTIFICATION TRAY ICONS === */

   #fr-layout-player-module-tray {
    border-top: 1px solid #8a6a40 !important;
    background-color: #a08060 !important;
    display: flex !important;
    justify-content: space-around !important;
    align-items: center !important;
    padding: 3px 0 3px 60px!important;
  }

/* Hide only the icon paths, not the whole SVG */
  .fr-layout-player-module-tray-icon svg path,
  .fr-layout-player-module-tray-icon svg ellipse {
    display: none !important;
  }

  /* Keep the SVG itself visible but transparent */
  .fr-layout-player-module-tray-icon svg {
    position: absolute !important;
    top: 0 !important;
    right: 0 !important;
    width: 80% !important;
    height: 80% !important;
  }

  /* make sure icon containers are position relative */
  .fr-layout-player-module-tray-icon {
    position: relative !important;
  }

/* DOT */
.fr-layout-player-module-tray-icon svg circle {
    fill: #ff7900 !important;
    stroke: #910000 !important;
    stroke-width: 2;
    r: 6 !important;
  }


 .fr-layout-player-module-tray-icon a,
  #fr-layout-alerts {
    opacity: 1 !important;
    filter: none !important;
    background-color: transparent !important;
    background-repeat: no-repeat !important;
    background-position: center !important;
    background-size: 24px 24px !important;
    width: 32px !important;
    height: 32px !important;
    display: inline-block !important;
  }


  #fr-layout-player-module-messages a {
    background-image: url("data:image/png;base64,") !important;
    background-size: 90% 60% !important;
  }

  #fr-layout-player-module-friend-requests a {
    background-image: url("data:image/png;base64,") !important;
  background-size: 65% !important
}

  #fr-layout-alerts {
    background-image: url("data:image/png;base64,") !important;
background-size: 40% !important
}

  #fr-layout-player-module-settings a {
    background-image: url("data:image/png;base64,") !important;
  background-size: 70% !important;
}


/*== OTHER USERS ==*/

.post-author-username-frame{
    color: #6b2000 !important;
    font-family: Verdana, sans-serif;
    font-size: 13px !important;
  }

.editor-author-username-frame{
    color: #6b2000 !important;
    font-family: Verdana, sans-serif;
    font-size: 13px !important;
  }

h1 {
    font-family: Verdana, sans-serif !important;
  }

#fr-layout-player-module-currencies a {
    font-family: Verdana, sans-serif !important;
    font-size: 10px !important;
    color: #6b2000 !important;
    text-decoration: none !important;
    
  }


.fr-layout-player-module-treasure svg ellipse {
    display: none !important;
  }


/*== WAYSTONE ==*/

  #fr-layout-sidebar-waystone {
    position: fixed !important;
    bottom: 0px !important;
    right: 140px !important;
    z-index: 999 !important;
  }




/*== DRAGON TOOLTIP ==*/
dragontip {
    font-family: Times New Roman, serif;
}
}