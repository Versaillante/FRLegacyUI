@-moz-document domain("flightrising.com") {
/* === OUTER MODULE === */

  #fr-layout-player-module {
    background-color: #b8a888 !important;
    border: 2px solid #8a6a40 !important;
    border-radius: 4px !important;
  }

  #fr-layout-player-module-main {
    background-color: #c8b898 !important;
    border: 2px solid #8a6a40 !important;
    border-radius: 3px !important;
    padding-bottom: 100px;
  }

  .fr-layout-player-module-username {
    color: #6b2000 !important;
    font-family: Verdana, sans-serif;
    font-size: 15px !important;
    padding: 0px 0px 3px 0px;
  }

  .fr-layout-player-module-left {
    border-right: 1px solid #8a6a40 !important;
    background-color: #c0a880 !important;
  }

  .theme-background-main-5,
  .theme-background-alt-5 {
    background-color: #eddcba !important;
  }

  .theme-border-5 {
    border-color: #8a6a40 !important;
  }

  .theme-text-accent-5 {
    color: #6b2000 !important;
  }


/* === ENERGY METER === */

  /* hide bar & hamburger menu */
  #fr-layout-player-module .common-meter-full {
      display: none !important;
}
   #fr-layout-player-module #fr-layout-player-module-energy-meter .common-meter-empty {
    display: none !important;
  }

  #fr-layout-player-module .fr-layout-player-module-energy-meter-line {
    display: none !important;
  }
  .common-meter-text svg {
    display: none !important;
  }

   /* Display text */
  #fr-layout-player-module .common-meter-text {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 10px !important;
    font-family: Verdana, sans-serif !important;
    color: #1a1a1a !important;
    z-index: 1 !important;
  }

  #fr-layout-player-module #fr-layout-player-module-energy-meter,
  #fr-layout-player-module .common-meter-frame {
    position: relative;
    height: 20px !important;
    min-height: unset !important;
    border-radius: 0 !important;
    border: none !important;
    overflow: hidden !important;
    background-image: url("data:image/jpeg;base64,") !important;
    background-size: 100% 105% !important;
    background-color: transparent !important;
  }




/* === CURRENCIES === */

#fr-layout-player-module-currencies {
    border-left: 2px solid #8a6a40 !important;
    border-right: 2px solid #8a6a40 !important;
    border-bottom: 1px solid #8a6a40 !important;
    background-color: #eddcba !important;
    display: flex !important;
    justify-content: space-evenly !important;
    align-items: center !important;
    padding: 0px 0 0px 0px!important;
  }

#fr-layout-player-module-currencies a {
    font-family: Verdana, sans-serif !important;
    font-size: 10px !important;
    color: #6b2000 !important;
    text-decoration: none !important;
    
  }

#fr-layout-player-module-treasure{
    background-image: url(https://www1.flightrising.com/static/layout/icon_treasure.png);
}



  /* === NOTIFICATION TRAY ICONS === */

   #fr-layout-player-module-tray {
    border-top: 1px solid #8a6a40 !important;
    background-color: #a08060 !important;
    display: flex !important;
    justify-content: space-around !important;
    align-items: center !important;
    padding: 3px 0 3px 60px!important;
  }

/* Hide only the icon paths, not the whole SVG */
  .fr-layout-player-module-tray-icon svg path,
  .fr-layout-player-module-tray-icon svg ellipse {
    display: none !important;
  }

  /* Keep the SVG itself visible but transparent */
  .fr-layout-player-module-tray-icon svg {
    position: absolute !important;
    top: 0 !important;
    right: 0 !important;
    width: 80% !important;
    height: 80% !important;
  }

  /* make sure icon containers are position relative */
  .fr-layout-player-module-tray-icon {
    position: relative !important;
  }

/* DOT */
.fr-layout-player-module-tray-icon svg circle {
    fill: #ff7900 !important;
    stroke: #910000 !important;
    stroke-width: 2;
    r: 6 !important;
  }

/* Colour unread alerts (by eyayah) */
.alert-v2 {
    background-color: #F1F0EE;
    border-radius: 10px 10px 0px 0px;
}

.alert-v2-unread, .theme-link-text-color-7 {
    background-color: #e8e0cf;
    border-radius: 0px;
    
}

.alert-v2-unread:first-child {
    border-radius: 10px 10px 0px 0px;
}


 .fr-layout-player-module-tray-icon a,
  #fr-layout-alerts {
    opacity: 1 !important;
    filter: none !important;
    background-color: transparent !important;
    background-repeat: no-repeat !important;
    background-position: center !important;
    background-size: 24px 24px !important;
    width: 32px !important;
    height: 32px !important;
    display: inline-block !important;
  }




  #fr-layout-player-module-messages a {
    background-image: url("data:image/png;base64,") !important;
    background-size: 90% 60% !important;
  }

  #fr-layout-player-module-friend-requests a {
    background-image: url("data:image/png;base64,") !important;
  background-size: 65% !important
}

  #fr-layout-alerts {
    background-image: url("data:image/png;base64,") !important;
background-size: 40% !important;
}

  #fr-layout-player-module-settings a {
    background-image: url("https://www1.flightrising.com/static/cms/icons/119.png") !important;
  background-size: 70% !important;
}


/*== OTHER USERS ==*/

.post-author-username-frame{
    color: #6b2000 !important;
    font-family: Verdana, sans-serif;
    font-size: 13px !important;
  }

.editor-author-username-frame{
    color: #6b2000 !important;
    font-family: Verdana, sans-serif;
    font-size: 13px !important;
  }

h1 {
    font-family: Verdana, sans-serif !important;
  }




/*== WAYSTONE ==*/

  #fr-layout-sidebar-waystone {
    position: fixed !important;
    bottom: 0px !important;
    right: 140px !important;
    z-index: 999 !important;
  }



/*== FOOD (by eyayah) ==*/
#fr-layout-banner-bar {
    font-size: 10px;
}
    
#fr-layout-food-points {
    left: 0;
    padding-left: 40px;
}

/*== SIDEBAR (by gunmute) ==*/
#fr-layout-navigation a.fr-layout-navigation-link:hover{
text-shadow: #fcf9de 0 0 4px, #fcf9de 0 0 4px;
background-color:transparent;
}
#fr-layout-navigation a.fr-layout-navigation-subheader:hover{
background-color:transparent;
}



/*== CONDENSED DRAGON TOOLTIP ==*/

/* Font */
.dragontip {
    font-family: Verdana, serif;
    font-size: 10px;
    color: #000;
}

/* Hide coloured bars and remove margin spacing */
#dragon-tip-details-module .theme-background-main-1{
    display: none !important;
}
.dragon-tip-detail.theme-background-alt2-1{
    background: transparent !important;
}

.dragon-tip-detail:after {
    display: table;
    content: none;
    clear: both;
}

/* Remove space between property and value*/
.dragon-tip-detail {
  display: flex !important;
  flex-direction: row !important;
  margin: -3px !important;
  padding: 2px 0px !important;
}

.dragon-tip-property {
  width: auto !important;
}

/* Add padding to various margins*/

.dragon-tip-property::before {
  content:"\00a0";
}
.dragon-tip-property::after {
  content:":\00a0";
}

.dragon-tip-detail:first-child {
  margin-top: 4px !important;
}

.dragon-tip-detail:last-child {
  margin-bottom: 4px !important;
}

.dragon-tip-broadcast {
  margin-top: 25px !important;
  margin-bottom: -5px !important;
}




/*== BUTTONS ==*/

.fr-theme[data-theme="default"] .theme-ui-1-disabled {
    background-color: #d1cbc2;
    border-color: #6c5d5d;
    color: #726e67;
    position: relative !important;
  overflow: hidden !important;
  
}


.theme-ui-1-disabled:after {
  content: ""; 
  position: absolute;
  top: -2px;
  left: -2.2px;
  width: 100%;
  height: 100%;
  background-color: rgba(113, 32, 32, .46); 
    
}


/* Outline */
.theme-ui-1-disabled .theme-svg-text-stroke {
  stroke: #71361c !important;
}

/* Fill */
.theme-ui-1-disabled .theme-svg-text-fill {
  fill: #fff !important;
}

/* Drop Shadow */
.theme-ui-1-disabled .theme-svg-text-shadow{
    fill: #5c6666 !important;
    x: 33;
    y: 33;
    font-size:medium;
    stroke-width:4; 
    filter: url(#blur);
}

.dragon-profile-dragon text,
.dragon-profile-familiar text {
  font-size: 14px !important;
}

.dragon-profile-interactives text {
  font-size: 16px !important;
}
}
